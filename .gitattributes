# Ensure Unix line endings for shell scripts regardless of developer OS
scripts/*.sh    text eol=lf

# Standard text files
*.py            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.md            text eol=lf
*.txt           text eol=lf
*.cfg           text eol=lf
*.ini           text eol=lf
*.conf          text eol=lf
*.service       text eol=lf
*.json          text eol=lf

# Binary files — no line-ending conversion
*.pyc           binary
*.png           binary
*.jpg           binary
*.ico           binary
